rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/usuarios_iser/$(request.auth.uid));
    }

    /** Visitante anónimo o rol en documento (viewer | admin). Sin documento: email = viewer. */
    function effectiveRole() {
      return !signedIn() ? null
        : (request.auth.token.firebase.sign_in_provider == 'anonymous' ? 'visitor'
          : (userProfile().exists ? userProfile().data.role : 'viewer'));
    }

    function isAdmin() {
      return signedIn() && userProfile().exists && userProfile().data.role == 'admin';
    }

    function canReadSharedData() {
      return signedIn() && (effectiveRole() == 'visitor' || effectiveRole() == 'viewer' || effectiveRole() == 'admin');
    }

    /** Perfiles: cada usuario lee el suyo; los admins leen todos. */
    /** Roles solo gestionables por admins (consola Firebase o SDK admin). Primer admin: crear documento manual en Console. */
    match /usuarios_iser/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /archivos_iser/{docId} {
      allow read: if canReadSharedData();
      allow create, update, delete: if isAdmin();
    }

    match /bloques_estado/{blockId} {
      allow read: if canReadSharedData();
      allow create, update, delete: if isAdmin();
    }

    match /auditorias_bloques/{blockId} {
      allow read: if canReadSharedData();
      allow create, update, delete: if isAdmin();
    }

    match /inventario_bloques/{blockId} {
      allow read: if canReadSharedData();
      allow create, update, delete: if false;
    }

    match /reportes_historial/{reportId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /capas_sig/{docId} {
      allow read: if canReadSharedData();
      allow create, update, delete: if isAdmin();
    }

    match /estadisticas/{docId} {
      allow read: if canReadSharedData();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
