rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios_iser/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios_iser/$(request.auth.uid)).data.role == "admin";
    }

    match /usuarios_iser/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /archivos_iser/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /bloques_estado/{blockId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /auditorias_bloques/{blockId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /inventario_bloques/{blockId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    match /reportes_historial/{reportId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /capas_sig/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /estadisticas/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
