rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados pueden leer
    // Solo admins autenticados (no anonimos) pueden escribir
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email != null;
    }

    // Colección auditorias_bloques: lectura para cualquier autenticado,
    // escritura desde Cloud Functions (admin SDK) o admins con email
    match /auditorias_bloques/{blockId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
