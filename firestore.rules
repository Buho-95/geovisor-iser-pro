rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════════
    function isAdminFromCollection(usersCol) {
      return request.auth != null
        && exists(/databases/$(database)/documents/$(usersCol)/$(request.auth.uid))
        && get(/databases/$(database)/documents/$(usersCol)/$(request.auth.uid)).data.role == "admin";
    }

    // Admin en producción (colección usuarios_iser)
    function isAdmin() { return isAdminFromCollection('usuarios_iser'); }

    // Admin en staging (colección staging_usuarios_iser)
    // Un admin de producción también lo es en staging (comodidad para QA).
    function isStagingAdmin() {
      return isAdminFromCollection('staging_usuarios_iser') || isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // PRODUCCIÓN — reglas originales
    // ═══════════════════════════════════════════════════════════════
    match /usuarios_iser/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /archivos_iser/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /bloques_estado/{blockId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /auditorias_bloques/{blockId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /inventario_bloques/{blockId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    match /reportes_historial/{reportId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /capas_sig/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /estadisticas/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Estructura canónica del Geovisor en producción (PDF oficial).
    // Cualquier usuario autenticado puede leerla; solo admin de producción la modifica.
    match /estructura_base/{sedeId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Carpetas dinámicas creadas por usuarios (zonas "rojo" del PDF: NN_Nombre).
    // Cualquier usuario autenticado puede leer para navegar; crear/editar/borrar es
    // privilegio de admin producción (para evitar spam y mantener integridad del árbol).
    match /estructura_dinamica/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════
    // STAGING — mismas reglas aplicadas a staging_* (aislamiento total)
    // ═══════════════════════════════════════════════════════════════
    match /staging_usuarios_iser/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isStagingAdmin());
      allow create, update, delete: if isStagingAdmin();
    }

    match /staging_archivos_iser/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isStagingAdmin();
    }

    match /staging_bloques_estado/{blockId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isStagingAdmin();
    }

    match /staging_auditorias_bloques/{blockId} {
      allow read: if isStagingAdmin();
      allow create, update, delete: if isStagingAdmin();
    }

    match /staging_inventario_bloques/{blockId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false; // solo funciones server-side
    }

    match /staging_reportes_historial/{reportId} {
      allow read: if isStagingAdmin();
      allow create, update, delete: if isStagingAdmin();
    }

    match /staging_capas_sig/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isStagingAdmin();
    }

    match /staging_estadisticas/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isStagingAdmin();
    }

    // Estructura canónica del Geovisor en staging (PDF oficial).
    // Cualquier usuario autenticado puede leerla; solo admin de staging la modifica.
    match /staging_estructura_base/{sedeId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isStagingAdmin();
    }

    // Carpetas dinámicas creadas por usuarios (zonas "rojo" del PDF: NN_Nombre).
    // Cualquier usuario autenticado puede leer para navegar; crear/editar/borrar es
    // privilegio de admin staging (para evitar spam y mantener integridad del árbol).
    match /staging_estructura_dinamica/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isStagingAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
