rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ═══════════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════════
    function isAdmin() {
      return request.auth != null && (
        (firestore.exists(/databases/(default)/documents/usuarios_iser/$(request.auth.uid))
          && firestore.get(/databases/(default)/documents/usuarios_iser/$(request.auth.uid)).data.role == 'admin')
        || request.auth.token.email == 'pedrojtrillos.arq@gmail.com'
      );
    }

    function isStagingAdmin() {
      return request.auth != null && (
        isAdmin() ||
        (firestore.exists(/databases/(default)/documents/staging_usuarios_iser/$(request.auth.uid))
          && firestore.get(/databases/(default)/documents/staging_usuarios_iser/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ═══════════════════════════════════════════════════════════════
    // PRODUCCIÓN
    // ═══════════════════════════════════════════════════════════════
    match /documentos_iser/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /auditorias/{allPaths=**} {
      allow read: if request.auth != null;
      allow write, delete: if isAdmin();
    }

    match /modelos_bim/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /capas_sig/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // STAGING — mismas reglas aplicadas a staging/* (aislamiento total)
    // ═══════════════════════════════════════════════════════════════
    match /staging/documentos_iser/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isStagingAdmin();
    }

    match /staging/auditorias/{allPaths=**} {
      allow read: if request.auth != null;
      allow write, delete: if isStagingAdmin();
    }

    match /staging/modelos_bim/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isStagingAdmin();
    }

    match /staging/capas_sig/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isStagingAdmin();
    }

    // Árbol jerárquico por sede (PDF oficial) — estructura completa en staging.
    // Permite upload controlado por la UI (modal sede→bloque→disciplina→subcarpeta).
    match /staging/sedes/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isStagingAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
