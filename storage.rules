rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Lectura: cualquier usuario autenticado (admin o visitor anónimo)
      allow read: if request.auth != null;
      // Escritura: solo usuarios con email (no anónimos)
      allow write: if request.auth != null && request.auth.token.email != null;
    }
  }
}
