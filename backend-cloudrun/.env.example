# ─── Geovisor ISER Pro — Backend Cloud Run (.env.example) ───────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio (está en .gitignore).

# ── Supabase ─────────────────────────────────────────────────────────────────
# URL del proyecto (Supabase Dashboard → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key (Supabase Dashboard → Settings → API → service_role)
# ⚠️ Clave PRIVADA — nunca exponerla en el frontend ni en el repositorio.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...tu_service_role_key

# Bucket principal de documentos
SUPABASE_STORAGE_BUCKET=documentos_iser

# ── Google Gemini ─────────────────────────────────────────────────────────────
# API Key de Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSy...tu_clave_gemini

# ── Servidor ─────────────────────────────────────────────────────────────────
# Cloud Run inyecta PORT automáticamente — usa 8080 para desarrollo local.
PORT=8080

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origen(es) del frontend.
# Producción: URL de Vercel (ej: https://geovisor-iser-pro.vercel.app)
# Desarrollo: http://localhost:5000
FRONTEND_ORIGIN=https://geovisor-iser-pro.vercel.app

# ── Admins de respaldo ────────────────────────────────────────────────────────
# Emails que actúan como admin si la tabla usuarios_iser no devuelve role='admin'.
# Separados por coma. Dejar vacío si la tabla es la única fuente de verdad (recomendado).
ADMIN_EMAILS=tu_email@dominio.com
