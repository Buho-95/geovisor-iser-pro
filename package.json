{
  "dependencies": {
    "@turf/turf": "^7.3.4",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/xhr-upload": "^5.1.1",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "firebase": "^12.10.0",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.19.0",
    "papaparse": "^5.5.3",
    "proj4": "^2.20.3",
    "three": "^0.135.0",
    "web-ifc": "^0.0.76",
    "web-ifc-viewer": "^1.0.218"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  },
  "name": "geovisoriser",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "sync-config": "node scripts/sync-config.js",
    "dev": "npm run sync-config && firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data --project geovisor-iser",
    "dev:fresh": "npm run sync-config && firebase emulators:start --project geovisor-iser",
    "dev:export": "firebase emulators:export ./emulator-data --project geovisor-iser",
    "preview:deploy": "npm run sync-config && firebase hosting:channel:deploy preview --expires 7d --project geovisor-iser",
    "staging:deploy:rules": "firebase deploy --only firestore:rules,storage --project geovisor-iser",
    "staging:deploy:functions": "npm run sync-config && firebase deploy --only functions --project geovisor-iser",
    "staging:deploy:hosting": "firebase hosting:channel:deploy staging --expires 30d --project geovisor-iser",
    "staging:deploy": "npm run staging:deploy:rules && npm run staging:deploy:functions && npm run staging:deploy:hosting",
    "staging:clone:dry": "node scripts/clone-to-staging.js",
    "staging:clone:apply": "node scripts/clone-to-staging.js --apply",
    "staging:clone:firestore": "node scripts/clone-to-staging.js --apply --only=firestore",
    "staging:clone:storage": "node scripts/clone-to-staging.js --apply --only=storage",
    "deploy:firebase": "npm run sync-config && firebase deploy --only hosting,functions,firestore,storage --project geovisor-iser",
    "deploy:prod": "npm run deploy:firebase"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Buho-95/Geovisor-nueva-interfaz-9-03-2026.git"
  },
  "keywords": [],
