{
  "name": "geovisor-iser-pro",
  "version": "2.0.0",
  "description": "Geovisor ISER Pro — CDE de auditoría normativa. Stack: Supabase + Cloud Run + Vercel.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "npx serve frontend -l 5000",
    "dev:backend": "cd backend-cloudrun && node --watch server.js",
    "build:css": "tailwindcss -i ./frontend/css/styles.css -o ./frontend/css/tailwind.out.css --watch",
    "build:css:prod": "tailwindcss -i ./frontend/css/styles.css -o ./frontend/css/tailwind.out.css --minify",
    "deploy:backend": "cd backend-cloudrun && gcloud run deploy geovisor-iser-backend --source . --region us-central1 --allow-unauthenticated",
    "seed:prod": "node scripts/seed-production-structure.js",
    "seed:prod:apply": "node scripts/seed-production-structure.js --apply",
    "apply:schema": "node apply-supabase-schema.js"
  },
  "dependencies": {
    "@turf/turf": "^7.3.4",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/xhr-upload": "^5.1.1",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.19.0",
    "papaparse": "^5.5.3",
    "proj4": "^2.20.3",
    "three": "^0.135.0",
    "web-ifc": "^0.0.76",
    "web-ifc-viewer": "^1.0.218"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Buho-95/Geovisor-nueva-interfaz-9-03-2026.git"
  },
  "keywords": ["geovisor", "supabase", "cloud-run", "vercel", "iser", "bim", "sig"],
  "author": "Pedro Johan Trillos Pérez",
  "license": "ISC"
}
