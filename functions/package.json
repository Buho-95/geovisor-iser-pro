{
  "name": "geovisor-iser-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions para Geovisor ISER",
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
